{
  "name": "@creator-cfo/mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "build": "__UNSAFE_EXPO_HOME_DIRECTORY=.expo-home expo export --platform web",
    "dev": "expo start --clear",
    "format": "prettier --check '**/*.{ts,tsx,json}'",
    "lint": "eslint app src tests --ext .ts,.tsx",
    "smoke": "pnpm test",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "node ./scripts/run-ios.mjs",
    "test": "vitest run tests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "web": "expo start --web"
  },
  "dependencies": {
    "@creator-cfo/schemas": "workspace:*",
    "@creator-cfo/storage": "workspace:*",
    "@creator-cfo/ui": "workspace:*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~55.0.8",
    "expo-apple-authentication": "~55.0.9",
    "expo-crypto": "~55.0.10",
    "expo-dev-client": "~55.0.19",
    "expo-document-picker": "~55.0.9",
    "expo-file-system": "~55.0.11",
    "expo-image-picker": "~55.0.14",
    "expo-linear-gradient": "~55.0.9",
    "expo-localization": "~55.0.9",
    "expo-router": "~55.0.7",
    "expo-sqlite": "~55.0.11",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-chart-kit": "^6.12.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
